# Use this file as a starter for your .env file, which
# must be placed at the root of the server.
NODE_ENV="development"
DATABASE_CONNECTION_STRING="mongodb+srv://user:pwd@cluster0.../trc"
DEV_DATABASE_CONNECTION_STRING="mongodb+srv://user:pwd@cluster0.../dev"
JWT_SECRET="some_secret_letters_numbers"
JWT_EXPIRATION="6d"
JWT_ISSUER=""
JWT_AUDIENCE=""
SENDGRID_KEY="SG.your.secret-key"
EMAIL_FROM=""
DB_LISTEN_PORT=""